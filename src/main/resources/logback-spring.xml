<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Capture JVM process start time — used in log file names so each run gets its own file -->
    <timestamp key="processStartTime" datePattern="yyyy-MM-dd_HH-mm-ss"/>

    <property name="LOG_DIR"  value="/tmp/logs/medvault"/>
    <property name="APP_NAME" value="medvault"/>

    <!-- ── Console appender (plain text, for local dev) ──────────────────── -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} [%X{correlationId}] - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- ── Console appender (JSON, for prod) ─────────────────────────────── -->
    <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeMdcKeyName>correlationId</includeMdcKeyName>
            <includeMdcKeyName>userId</includeMdcKeyName>
        </encoder>
    </appender>

    <!--
        ── Rolling file appender ────────────────────────────────────────────
        Active log file:  /tmp/logs/medvault/medvault-<start-time>.log
        Rolled archives:  /tmp/logs/medvault/archived/medvault-<start-time>.<date>.<index>.log.gz
        Rolls:            daily OR when a single file hits 50 MB
        Retention:        30 days / 500 MB total cap — whichever is reached first
    -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/${APP_NAME}-${processStartTime}.log</file>

        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/archived/${APP_NAME}-${processStartTime}.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>50MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>500MB</totalSizeCap>
        </rollingPolicy>

        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} [%X{correlationId}] [%X{userId}] - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- ── Profile: local — console + file ───────────────────────────────── -->
    <springProfile name="local">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </root>
        <!-- Quiet down noisy Spring internals -->
        <logger name="org.springframework.web"         level="DEBUG"/>
        <logger name="org.hibernate.SQL"               level="DEBUG"/>
        <logger name="org.hibernate.type.descriptor"   level="TRACE"/>
    </springProfile>

    <!-- ── Profile: prod — JSON console + file ───────────────────────────── -->
    <springProfile name="prod">
        <root level="INFO">
            <appender-ref ref="JSON_CONSOLE"/>
            <appender-ref ref="FILE"/>
        </root>
        <logger name="org.springframework" level="WARN"/>
        <logger name="org.hibernate"       level="WARN"/>
    </springProfile>

    <!-- ── Fallback (no profile set) ─────────────────────────────────────── -->
    <springProfile name="!local &amp; !prod">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </root>
    </springProfile>

</configuration>
